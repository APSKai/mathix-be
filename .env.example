URL=127.0.0.1
PORT=4000

API_PUBLIC_URL=https://api.trackify.io.vn
CLIENT_PUBLIC_URL=https://app.trackify.io.vn
ADMIN_PUBLIC_URL=https://admin.trackify.io.vn

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=mathix:api
REDIS_CONNECT_TIMEOUT_MS=500
REDIS_COMMAND_TIMEOUT_MS=500

RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=600
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_PLAYER_WINDOW_MS=60000
RATE_LIMIT_PLAYER_MAX=120
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=120

CACHE_TTL_PUBLIC_SECONDS=300
CACHE_TTL_HOME_SECONDS=60
CACHE_TTL_META_SECONDS=3600
CACHE_TTL_CATALOG_SECONDS=600
CACHE_TTL_INTERACTION_SECONDS=30

# Firebase
FIREBASE_API_KEY=your_web_api_key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
